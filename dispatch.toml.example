# dispatch.toml — copy to ~/.config/dispatch/dispatch.toml and edit.
#
# Each [[repo]] block tells dispatch:
#   - which GitHub repo to watch
#   - which vault to file new issues into (must be registered with oteam)
#   - which existing project gets the ticket (dispatch never auto-creates)
#   - whether dispatch may write labels back to the GitHub issue
#   - autopilot tier: off | curate-only | fire (see below)
#
# Tickets are filed via `oteam pull github <issue-url>`. The configured
# vault must be registered (`oteam config vault list`) and the configured
# project must exist (`oteam project list --vault <vault>`); otherwise
# dispatch refuses to file. The recommended pattern is a single
# `triage-inbox` project per vault — every repo funnels into it, and the
# vault's role pipeline re-files into the right active work stream.
#
#   oteam project init triage-inbox --vault <vault> --no-edit
#
# Override per-repo by setting `project = "<active-work-stream>"` if
# you want a specific repo's issues to land directly in an active stream.
#
# First run on a new repo: dispatch seeds the cursor to "now" and ingests
# nothing historical. To backfill, edit cursors.json by hand.
#
# ─── autopilot ───
# off          → ingest only. Tickets sit in triage waiting for human action. (default)
# curate-only  → also run the curator agent, which dedupes/checks the ticket and
#                either closes the GH issue (clean dup), holds with comment, or
#                green-lights. Green-lit tickets are NOT auto-fired in this mode.
# fire         → curate AND, for green-lit tickets, autonomously fire `oteam assign`
#                to drive the role pipeline. Most aggressive; reserve for repos
#                where you fully trust the agent fleet to act unsupervised.
#
# When any repo is in fire mode, dispatch claims the GH issue (sets `assignees`
# to `defaults.bot_identity`) before invoking `oteam assign`. Other actors
# (humans assigning themselves in the GH UI, other dispatch instances) cause
# the claim to fail and the ticket transitions to `lost-race` instead of firing.

[defaults]
state_dir                          = "~/.local/state/dispatch"
log_dir                            = "~/Library/Logs/dispatch"
poll_interval_minutes              = 5
triage_model                       = "claude-haiku-4-5-20251001"
body_truncate_chars                = 8000

# Curator + orchestrator knobs
curator_model                      = "claude-sonnet-4-6"
per_call_max_budget_usd            = 0.50
per_tick_max_budget_usd            = 2.00
max_orchestrator_spawns_per_tick   = 1
recent_vault_tickets_window_days   = 60
recent_vault_tickets_cap           = 40

# GitHub login that the curator uses to claim issues before firing the
# orchestrator. Required when any repo has `autopilot = "fire"`. The
# operator's own login is the simplest choice; a dedicated bot account
# works if the operator wants to disambiguate human vs. automated claims
# in the GH UI.
bot_identity                       = ""

# ─────────────────────────────────────────────────────────────────
# Examples — replace with your own repos.
# ─────────────────────────────────────────────────────────────────

# Default: ingest only. Curator does not run; tickets queue for you.
[[repo]]
slug      = "myorg/my-app"
vault     = "my-vault"
project   = "triage-inbox"
can_label = true
autopilot = "off"

# Curate but don't fire: agent dedupes, comments on dups, holds for human.
# Useful for repos where you want signal extracted but not unsupervised execution.
[[repo]]
slug      = "anotherorg/some-lib"
vault     = "my-vault"
project   = "triage-inbox"
can_label = false
autopilot = "curate-only"

# Full autopilot: curator green-lights → oteam assign fires automatically.
# Reserve for low-stakes / well-tested repos.
[[repo]]
slug      = "myorg/sandbox-toy"
vault     = "my-vault"
project   = "triage-inbox"
can_label = true
autopilot = "fire"
