# dispatch.toml — copy to ~/.config/dispatch/dispatch.toml and edit.
#
# ⚠ SPIKE NOTICE — this file documents the v2 sources+rules schema for the
#   experimental `dispatch poll --v2` code path. The default `dispatch poll`
#   (no --v2) is still on the v0 schema (`[[repo]]` blocks); copying this file
#   to ~/.config/dispatch/dispatch.toml and running plain `dispatch poll`
#   produces a do-nothing config with no error. Until the v2 path graduates
#   from spike, keep your v0 dispatch.toml in place and either:
#     - put this file at a parallel path like ~/.config/dispatch/dispatch-v2.toml
#     - point dispatch at it with `DISPATCH_CONFIG=<path> dispatch poll --v2`
#
# Configuration model:
#   1. [defaults]            — global knobs (state dir, models, budgets)
#   2. [[source.<kind>]]     — where items come from
#                              (github_issues, github_prs, folder)
#   3. [[rule.ingest]]       — one-shot match at ingest time; picks
#                              vault / project / autopilot / sink
#   4. [[rule.lifecycle]]    — reactive match on vault-state transitions;
#                              re-fires orchestrator phases, transitions
#                              states, generalizes drive-mode
#   5. [default]             — fallback action when no ingest rule matches
#
# Rule matching is first-match-wins in declaration order. `when` keys are
# AND-ed; an omitted key matches anything. `do` keys are applied in the
# matched rule's order. The `[default]` block applies if no ingest rule
# matches; its absence means "drop the item".
#
# ─── autopilot tiers (chosen per ingest rule via do.autopilot) ───
# off          → file the ticket and stop. Awaits human action.
# curate-only  → also run the curator (dedupe / hold / green-light).
#                Green-lit tickets are not auto-fired.
# fire         → curate AND, on green-light, autonomously fire
#                `oteam assign` ONCE — drives the first phase only.
# drive        → like fire, but lifecycle rules keep re-firing each
#                phase advance until the ticket reaches a terminal
#                vault state. Most autonomous tier.
#
# When a matched rule's `do.autopilot` is "fire" or "drive" and the
# source kind is `github_issues`, dispatch claims the GH issue (sets
# `assignees` to `defaults.bot_identity`) before invoking the orchestrator.

[defaults]
state_dir                          = "~/.local/state/dispatch"
log_dir                            = "~/Library/Logs/dispatch"
poll_interval_minutes              = 5
triage_model                       = "claude-haiku-4-5-20251001"
curator_model                      = "claude-sonnet-4-6"
body_truncate_chars                = 8000
per_call_max_budget_usd            = 0.50
per_tick_max_budget_usd            = 2.00
max_orchestrator_spawns_per_tick   = 1
recent_vault_tickets_window_days   = 60
recent_vault_tickets_cap           = 40

# GitHub login the orchestrator-claim step uses for github_issues sources.
# Required when any ingest rule sets do.autopilot = "fire" or "drive"
# against a github_issues source.
bot_identity                       = ""

# ─────────────────────────────────────────────────────────────────
# Sources
# ─────────────────────────────────────────────────────────────────
# `name` is the source's identifier in rule matches (when.source = "...").
# Sources do NOT decide where their items go — rules do that.

[[source.github_issues]]
name      = "myapp-issues"
slug      = "myorg/my-app"
can_label = true

[[source.github_prs]]
name      = "myapp-prs"
slug      = "myorg/my-app"

# Drop a markdown file into `path`. Dispatch ingests it and moves it
# into `archive` (or deletes if archive is unset).
[[source.folder]]
name      = "inbox"
path      = "~/Inbox/dispatch"
archive   = "~/Inbox/dispatch/.processed"
pattern   = "*.md"

# Linear issues. Requires LINEAR_API_KEY in the env. `team` is the team
# key (e.g. "ENG"), not the team UUID. Optional `state` and `project`
# filter narrow the fetched set.
[[source.linear]]
name      = "linear-eng"
team      = "ENG"
# state   = "Todo"
# project = "Platform"

# ─────────────────────────────────────────────────────────────────
# Ingest rules — fire once per new item, in declaration order.
# ─────────────────────────────────────────────────────────────────

# Anything triage flags as security goes to the local inbox and never
# touches the vault. Matches across ALL sources.
[[rule.ingest]]
name      = "security-holds-everything"
when.type = "security"
do.sink   = "security-inbox"

# Bugs filed in the main repo get curator dedupe but no auto-fire.
[[rule.ingest]]
name           = "bugs-curate-only"
when.source    = "myapp-issues"
when.type      = "bug"
do.vault       = "my-vault"
do.project     = "triage-inbox"
do.autopilot   = "curate-only"

# Feature requests in the main repo land in the roadmap project.
[[rule.ingest]]
name           = "features-roadmap"
when.source    = "myapp-issues"
when.type      = "feature"
do.vault       = "my-vault"
do.project     = "roadmap"
do.autopilot   = "off"
do.add_labels  = ["from-dispatch"]

# Inbound PRs auto-fire a review phase.
[[rule.ingest]]
name           = "pr-reviews-fire"
when.source    = "myapp-prs"
do.vault       = "my-vault"
do.project     = "active-prs"
do.autopilot   = "fire"

# Notes dropped in the inbox folder become ideas. No curator, no fire.
[[rule.ingest]]
name           = "inbox-as-ideas"
when.source    = "inbox"
do.vault       = "my-vault"
do.project     = "ideas"
do.autopilot   = "off"

# ─────────────────────────────────────────────────────────────────
# Lifecycle rules — fire on vault-state transitions.
#
# ⚠ SPIKE: lifecycle rules are SPEC-ONLY in the current spike. The
#   [[rule.lifecycle]] blocks below parse and validate, but the engine
#   that fires them (per-tick vault-state diffing) is the next phase.
#   autopilot=drive's re-fire-on-state-advance now lives here — drive items
#   are filed + initially fired by the ingest path, then advance phase by
#   phase as the role pipeline transitions vault state.
# ─────────────────────────────────────────────────────────────────
# `when.from_state` / `when.to_state` match a state transition.
# `when.state`   matches the current state on every poll tick (no transition required).
# `when.stuck_for_minutes` matches when a ticket has sat in its current state >= N minutes.
# `do.spawn`     runs an argv-split command (split on whitespace ONLY — no shell;
#                use a wrapper script for pipes/redirects/quoted args). The matched
#                ticket's absolute path is appended as the final argv element, so
#                the spawned command always knows which ticket triggered the rule.
# `do.notify`    fires a best-effort macOS notification.
#
# Vault state mutations (writing the ticket's `state:` frontmatter, moving
# files between lifecycle folders) are owned by oteam, not dispatch. There
# is no `do.transition` action; phase advances are expressed by spawning an
# orchestrator command that itself updates state.

[[rule.lifecycle]]
name           = "advance-after-spike"
when.to_state  = "spike-done"
do.spawn       = "oteam assign --phase implementation"

[[rule.lifecycle]]
name           = "advance-after-implementation"
when.to_state  = "implementation-done"
do.spawn       = "oteam assign --phase qa"

# Notify on entry to a terminal state.
[[rule.lifecycle]]
name           = "notify-on-done"
when.to_state  = "done"
do.notify      = true

# Notify if a ticket has been stuck in its current state for an hour.
[[rule.lifecycle]]
name                     = "notify-on-stuck"
when.stuck_for_minutes   = 60
do.notify                = true

# ─────────────────────────────────────────────────────────────────
# Default action — applied when no [[rule.ingest]] matches.
# Omit this block to drop unmatched items silently.
# ─────────────────────────────────────────────────────────────────

[default]
sink      = "vault"
vault     = "my-vault"
project   = "triage-inbox"
autopilot = "off"
