#!/usr/bin/env bash
# dispatch CLI shim. Resolves bun via PATH; launchd uses absolute paths
# in the plist instead of this shim.
set -e
src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$src")" && pwd)"
exec bun "$SCRIPT_DIR/../src/cli.ts" "$@"
